{
  "info": {
    "name": "Project Management API",
    "description": "Multi-tenant Project Management REST API. Run requests top-to-bottom: Register → Login → CRUD Projects → Invites. Cookies auto-persist in Postman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/v1"
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "inviteId",
      "value": ""
    },
    {
      "key": "inviteToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ok', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (New Org)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user data', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.data).to.have.property('id');",
                  "  pm.expect(res.data).to.have.property('email');",
                  "  pm.expect(res.data).to.have.property('tenantId');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@acme.com\",\n  \"password\": \"supersecure1\",\n  \"name\": \"Alice Owner\",\n  \"tenantName\": \"Acme Inc\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.data).to.have.property('id');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@acme.com\",\n  \"password\": \"supersecure1\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has JWT payload', () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.data).to.have.property('userId');",
                  "  pm.expect(res.data).to.have.property('tenantId');",
                  "  pm.expect(res.data).to.have.property('email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/me"
